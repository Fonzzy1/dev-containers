#!/bin/bash
set -e

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )"

if [ "$1" = "--init" ]; then

## This should be re-runnable from any ubuntu-server os

sudo timedatectl set-timezone Australia/Melbourne

## Load in the apps that I use for viewing media
sudo apt-get -y update
sudo apt-get -y upgrade
sudo apt-get -y install --no-install-recommends \
    i3 \
    i3status \
    xorg \
    xinit \
    dbus-x11 \
    xterm \
    jq \
    git \
    curl \
    wget \
    unzip \
    make \
    build-essential \
    python3-pip \
    pipx \
    xclip \
    libxkbcommon-dev \
    libxkbcommon-x11-0 \
    just \
    zathura \
    feh \
    mpv \
    ranger \
    dex \
    xss-lock \
    i3lock \
    dmenu \
    network-manager \
    ubuntu-drivers-common \
    qutebrowser \
    gnome-keyring \
    libsecret-1-dev \
    alsa-utils \
    pipewire \
    wireplumber \
    pipewire-pulse \
    pmount

#Audio    
systemctl --user daemon-reload
systemctl --user enable --now pipewire.service
systemctl --user enable --now pipewire-pulse.service
systemctl --user enable --now wireplumber.service



# Snaps
sudo snap install nordpass
sudo snap connect nordpass:password-manager-service

# Drivers
sudo ubuntu-drivers install

#font
wget -O JetBrainsMono.zip "https://github.com/ryanoasis/nerd-fonts/releases/download/v3.4.0/JetBrainsMono.zip" && rm -rf JetBrainsMono && unzip -o JetBrainsMono.zip -d JetBrainsMono && mkdir -p ~/.local/share/fonts && cp -rf JetBrainsMono/* ~/.local/share/fonts/ && fc-cache -fv

## Kitty
curl -L https://sw.kovidgoyal.net/kitty/installer.sh | sh /dev/stdin \
    installer=nightly
sudo ln -sf ~/.local/kitty.app/bin/kitty /usr/bin/kitty

## Docker install
if ! command -v docker &> /dev/null; then
    echo "Docker is not installed. Proceeding with installation."
    curl -fsSL https://nvidia.github.io/libnvidia-container/gpgkey | sudo gpg --dearmor -o /usr/share/keyrings/nvidia-container-toolkit-keyring.gpg
    curl -s -L https://nvidia.github.io/libnvidia-container/stable/deb/nvidia-container-toolkit.list | sed 's#deb https://#deb [signed-by=/usr/share/keyrings/nvidia-container-toolkit-keyring.gpg] https://#g' | sudo tee /etc/apt/sources.list.d/nvidia-container-toolkit.list
    sudo apt-get update
    sudo curl -fsSL https://get.docker.com -o install-docker.sh
    sudo sh install-docker.sh
    sudo rm install-docker.sh
    sudo usermod -aG docker "$USER"
    sudo apt-get install -y nvidia-container-toolkit
    echo "Docker installation complete!"
else
    echo "Docker is already installed."
fi

curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y
export PATH="$HOME/.cargo/bin:$PATH"

cp "$SCRIPT_DIR"/dotfiles/.bashrc "$HOME"/.bashrc

echo 'if [ -z "$DISPLAY" ]; then
  exec startx
fi' > ~/.bash_profile



# i3 theme
mkdir -p "$HOME/.config/i3" && curl -L -o "$HOME/.config/i3/config" https://github.com/catppuccin/i3/raw/refs/heads/main/themes/catppuccin-latte

cat <<'EOF' >> "$HOME/.config/i3/config"
set $mod Mod4
floating_modifier $mod

font pango:JetBrainsMono Nerd Font 11

exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id feh --bg-scale .wallpaper
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork

set $refresh_i3status killall -SIGUSR1 i3status

bindsym $mod+Return exec kitty
bindsym $mod+f exec kitty -e ranger
bindsym $mod+b exec qutebrowser
bindsym $mod+n exec nordpass
bindsym $mod+q kill

bindsym $mod+slash exec "dmenu_run -fn 'JetBrainsMono Nerd Font-11' -p 'Run:' -nf '$text' -nb '$mantle' -sf '$crust' -sb '$yellow'"
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+m fullscreen toggle

bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle

bindsym $mod+Shift+r restart

mode "resize" {
    bindsym h resize shrink width 10 px or 10 ppt
    bindsym j resize grow height 10 px or 10 ppt
    bindsym k resize shrink height 10 px or 10 ppt
    bindsym l resize grow width 10 px or 10 ppt
    bindsym Return mode "default"
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}

bindsym $mod+r mode "resize"

default_border pixel 2
default_floating_border pixel 2

client.focused           $yellow $base $text  $rosewater $yellow
client.focused_inactive  $overlay0 $base $text  $rosewater $overlay0
client.unfocused         $overlay0 $base $text  $rosewater $overlay0
client.urgent            $peach    $base $peach $overlay0  $peach
client.placeholder       $overlay0 $base $text  $overlay0  $overlay0
client.background        $base

bar {
    font pango:JetBrainsMono Nerd Font 11
    position top
    status_command i3status
    workspace_buttons no
    binding_mode_indicator no

    colors {
        background         $mantle
        statusline         $text
        focused_statusline $text
        separator          $surface2
        focused_separator  $surface2

        focused_workspace  $base  $yellow    $crust
        active_workspace   $base  $surface2 $text
        inactive_workspace $base  $base     $text
        urgent_workspace   $base  $red      $crust
    }
}

EOF

mkdir -p "$HOME/.config/i3status"
cat <<'EOF' > "$HOME/.config/i3status/config"
general {
    colors = true
    interval = 5
    color_good = "#40a02b"
    color_degraded = "#df8e1d"
    color_bad = "#d20f39"
}

order += "wireless _first_"
order += "ethernet _first_"
order += "battery all"
order += "disk /"
order += "memory"
order += "cpu_usage"
order += "tztime local"

wireless _first_ {
    format_up = "wifi: %essid %quality %ip"
    format_down = "wifi: down"
}

ethernet _first_ {
    format_up = "eth: %ip"
    format_down = "eth: down"
}


disk "/" {
    format = "disk: %avail"
}

memory {
    format = "mem: %used / %total"
    threshold_degraded = "80%"
    format_degraded = "mem: %used / %total"
}

cpu_usage {
    format = "cpu: %usage"
}

tztime local {
    format = "%Y-%m-%d %H:%M"
}
EOF


# Kitty theme
mkdir -p "$HOME"/.config/kitty
curl https://raw.githubusercontent.com/catppuccin/kitty/refs/heads/main/themes/latte.conf -o ~/.config/kitty/kitty.conf
echo "enable_audio_bell no" >> ~/.config/kitty/kitty.conf
echo "hide_window_decorations no" >> ~/.config/kitty/kitty.conf
echo "font_family JetBrainsMono Nerd Font" >> ~/.config/kitty/kitty.conf


# Zathura Theme
mkdir -p "$HOME"/.config/zathura
wget -O "$HOME"/.config/zathura/catppuccin-latte https://raw.githubusercontent.com/catppuccin/zathura/refs/heads/main/themes/catppuccin-latte
echo '
include catppuccin-latte
set selection-clipboard clipboard
' > "$HOME"/.config/zathura/zathurarc
# Make zathura default for all pdf in xmim
xdg-mime default org.pwmt.zathura-pdf-poppler.desktop application/pdf
xdg-mime default org.pwmt.zathura-pdf-poppler.desktop application/x-pdf

# Feh Theme
mkdir -p "$HOME"/.config/feh
wget -O "$HOME"/.config/feh/keys https://gist.githubusercontent.com/yudi-matsuzake/688a6273339cbb2d7a97a53d0d8ab6c7/raw/74193d26f849353eb578d9da30106170cf9927c9/keys
xdg-mime default feh.desktop image/jpeg
xdg-mime default feh.desktop image/png
xdg-mime default feh.desktop image/gif
xdg-mime default feh.desktop image/bmp
xdg-mime default feh.desktop image/svg
xdg-mime default feh.desktop image/svg+xml

# Ranger
xdg-mime default ranger.desktop inode/directory
mkdir -p ~/.config/ranger
echo '# rifle.conf
# By default, use Vim for most files
mime ^text,  label editor = vim -- "$@"
has xdg-open, flag f = xdg-open "$1"' > "$HOME"/.config/ranger/rifle.conf

# Wallpaper
# # Fetch the image from the url using wget and save it into the specific directory
cp "$SCRIPT_DIR"/dotfiles/.wallpaper ~/.wallpaper


CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/qutebrowser"
CONFIG_FILE="$CONFIG_DIR/config.py"

mkdir -p "$CONFIG_DIR"

cat > "$CONFIG_FILE" <<'EOF'
# QUTE BROWSER
##
import os
from urllib.request import urlopen

config.load_autoconfig()

# Always use windows instead of tabs where possible
c.tabs.tabs_are_windows = True

# Hide the tab bar
c.tabs.show = 'never'
c.statusbar.position = 'top'
c.statusbar.show = 'in-use'

# Default search engine: Google
c.url.searchengines = {
    'DEFAULT': 'https://www.google.com/search?q={}',
}

if not os.path.exists(config.configdir / "theme.py"):
    theme = "https://raw.githubusercontent.com/catppuccin/qutebrowser/main/setup.py"
    with urlopen(theme) as themehtml:
        with open(config.configdir / "theme.py", "w") as file:
            file.write(themehtml.read().decode("utf-8"))

if os.path.exists(config.configdir / "theme.py"):
    import theme
    theme.setup(c, 'latte', True)
EOF



fi

mkdir -p ~/.local/bin 
ln -sf "$SCRIPT_DIR"/runit ~/.local/bin/runit

# Delete and make the pipe
rm -rf ~/pipe
mkfifo ~/pipe 
nohup bash -c '
  while true; do
    eval "$(cat ~/pipe)" &> ~/.pipe_logs.txt
  done
' > ~/nohup_main.log 2>&1 &

xhost + local:

# Build the docker image if there have been changes
cd "$SCRIPT_DIR"
./build


echo "Setup complete!"
