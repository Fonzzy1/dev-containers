{
    "tasks": [
        {
            "name": "Quarto Preview",
            "cmd": "quarto preview ${file}",
            "tags": ["quarto"]
        },
        {
            "name": "Quarto Render",
            "cmd": "quarto render ${file}",
            "tags": ["quarto"]
        },
        {
            "name": "Docker Build",
            "cmd": "docker build -f ${file} ${config_dir}",
            "tags": ["docker"]
        },
        {
            "name": "Docker Run",
            "cmd": "docker run ${file}",
            "tags": ["docker"]
        },
        {
            "name": "Open Shell",
            "cmd": "bash",
            "tags": ["shell"]
        },
        {
            "name": "Docker Compose Up",
            "cmd": "docker compose up --build",
            "tags": ["docker", "compose"]
        },
        {
            "name": "Install Python Requirements",
            "cmd": "pip install --break-system-packages -r requirements.txt",
            "tags": ["python", "pip"]
        }
    ]
}
