{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/gpt-5.1",
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "lsp": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "codesearch": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "question": "allow",
    "edit": {
      "*": "ask",
      "/tmp": "allow",
      "/tmp/**": "allow"
    },
    "bash": {
      "*": "ask",
      // Destructive commands auto-allowed only for /tmp scratch space
      "rm /tmp/*": "allow",
      "rm -r /tmp/*": "allow",
      "rm -rf /tmp/*": "allow",
      "mkdir /tmp/*": "allow",
      "mv /tmp/*": "allow"
    },
    "external_directory": {
      "/tmp": "allow",
      "/tmp/**": "allow"
    }
  },
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    }
  }
}
