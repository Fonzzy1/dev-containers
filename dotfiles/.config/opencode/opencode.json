            "/tmp/*": "allow"
        },
        "glob": "deny",
        "grep": "deny",
        "bash": "deny",
        "task": "deny",
        "lsp": "deny",
        "question": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "codesearch": "deny",
