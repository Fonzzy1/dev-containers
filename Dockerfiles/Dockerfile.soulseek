FROM node:24-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    libsecret-1-dev \
    gnome-keyring \
    dbus \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g soulseek-cli

ENTRYPOINT ["sh", "-c", "exec dbus-run-session -- sh -c 'echo root | gnome-keyring-daemon --unlock --components=secrets >/dev/null 2>&1; exec soulseek \"$@\"' sh \"$@\"", "--"]
